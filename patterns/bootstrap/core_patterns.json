      "trigger_conditions": {
        "session_duration_minutes": 30,
        "knowledge_density": 0.5,
        "solution_count": 2
      },
      "success_criteria": {
        "pattern_identification": 0.7,
        "content_extraction": 0.8,
        "categorization_accuracy": 0.8
      },
      "template_file": "knowledge-extraction.tmpl",
      "tags": ["knowledge", "extraction", "reusability"],
      "priority": "high"
    }
  ]
}
