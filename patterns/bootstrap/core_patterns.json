      "template_file": "progress-report.tmpl",
      "tags": ["progress", "tracking", "metrics"],
      "priority": "medium"
    },
    {
      "id": "knowledge-extraction",
      "name": "Knowledge Extraction",
      "category": "KnowledgeExtraction",
      "meta_level": "System",
      "description": "Extract reusable knowledge and insights from AI agent interactions",
      "workflow_steps": [
        {
          "step": 1,
          "action": "identify_knowledge_patterns",
          "description": "Identify patterns and knowledge structures"
        },
        {
          "step": 2,
          "action": "extract_reusable_content",
          "description": "Extract reusable content and solutions"
        },
        {
          "step": 3,
          "action": "categorize_knowledge",
          "description": "Categorize knowledge by domain and type"
        },
        {
          "step": 4,
          "action": "tag_knowledge",
          "description": "Apply tags and metadata for organization"
        },
        {
          "step": 5,
          "action": "assess_reusability",
          "description": "Assess reusability and value of extracted knowledge"
        }
